{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Solevup",
  "version": "0.1.3",
  "identifier": "com.solevup.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5172",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Solevup",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 200,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
