{
  "manifest_version": 3,
  "name": "Solevup 专注锁",
  "version": "0.1.0",
  "description": "Solevup 桌面端的网站屏蔽执行器——专注期间拦截分心网站。",
  "key": "",
  "minimum_chrome_version": "121",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": false,
      "js": ["matcher.js", "content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "declarativeNetRequest",
    "nativeMessaging",
    "tabs",
    "alarms",
    "storage"
  ],
  "host_permissions": ["<all_urls>"]
}
