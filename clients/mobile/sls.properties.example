# Solo Leveling mobile — 本地配置（复制为 sls.properties，已 gitignore）
# 用于 gradle 注入 BuildConfig 字段，给 Updater native module 读
#
# 注意拆分：
# - BuildConfig.SLS_UPDATE_MANIFEST_URL（gradle 读这里）→ 检查 latest.json
#   永远走 OSS 原生域 https://{bucket}.{endpoint}，不走 CDN，避免 CDN 边缘
#   节点忽略 Cache-Control 缓存住旧版本
# - manifest 里 APK 的 url 字段 → 由发布脚本 (.env 的 OSS_CUSTOM_DOMAIN)
#   注入，走 CNAME 域。OSS 禁止用原生 *.aliyuncs.com 分发 .apk
#   (ApkDownloadForbidden)，APK 必须走 CNAME
# - 因此这里的 ossCustomDomain 字段当前 gradle 不再使用，仅供其它用途
#   或与 .env 对齐

# 阿里云 OSS endpoint
ossEndpoint=oss-cn-heyuan.aliyuncs.com
# OSS bucket 名
ossBucket=lingflow
# OSS 路径前缀（latest.json 会在 {prefix}/android/latest.json）
ossPathPrefix=solo-leveling
# 自定义 CNAME 域 —— 仅供文档对齐；APK 走这个域由 .env 控制（发布脚本读）
ossCustomDomain=https://assets.lingflow.cn
