# Solo Leveling System .env 模板
# 复制为 .env（gitignore），填上自己的值
# 用途：release_mobile.py 发布脚本读取 OSS 凭证 + 端点

# 阿里云 OSS Access Key
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# sls 用的 bucket + endpoint（与其他项目分开建一个）
OSS_BUCKET_NAME=lingflow
OSS_ENDPOINT=oss-cn-heyuan.aliyuncs.com

# CNAME / CDN 域。OSS 禁止用 *.aliyuncs.com 原生域分发 .apk
# （ApkDownloadForbidden），必须配 CNAME 自定义域
OSS_CUSTOM_DOMAIN=https://assets.lingflow.cn

# sls 在 bucket 内的路径前缀，对应 OSS 上 {prefix}/android/latest.json
SLS_OSS_PATH_PREFIX=solo-leveling
